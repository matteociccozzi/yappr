# yappr-generated runtime data
recordings/
logs/
metrics/
metrics.bak.*/

# FluidAudio is a vendored dependency, not part of this repo. To set up:
#   git clone https://github.com/FluidInference/FluidAudio.git vendor/FluidAudio
#   cd vendor/FluidAudio && swift build -c release
vendor/FluidAudio/

# Swift build output for the local daemon
swift/yappr-stt-daemon/.build/
swift/yappr-stt-daemon/.swiftpm/
swift/yappr-stt-daemon/Package.resolved

# Python cache
__pycache__/
*.pyc

# Temp / scratch
*.tmp
*.bak
.DS_Store
