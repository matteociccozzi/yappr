{
  "version": "v3-streaming",
  "description": "Streaming STT (Nemotron 0.6B @ 560ms via yappr-stt-daemon) + Qwen3-1.7B-4bit cleanup via yappr-mlx-server.",
  "backend": "yappr-mlx-server",
  "llm": {
    "url": "http://127.0.0.1:8081/v1/chat/completions",
    "model_name": "mlx-community/Qwen3-1.7B-4bit",
    "max_tokens": 512,
    "temperature": 0,
    "extra_params": {
      "chat_template_kwargs": {"enable_thinking": false}
    }
  },
  "prompt_file": "prompts/cleanup.txt"
}
