{
  "version": "default",
  "description": "Default baseline: Qwen3-1.7B-4bit via custom yappr-mlx-server with explicit prefix caching (port 8081).",
  "backend": "yappr-mlx-server",
  "llm": {
    "url": "http://127.0.0.1:8081/v1/chat/completions",
