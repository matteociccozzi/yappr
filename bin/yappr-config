#!/usr/bin/env bash
# yappr-config — manage versioned cleanup configs for yappr.
#
# Usage:
#   yappr-config list                  Show all configs, mark the active one
#   yappr-config active                Print the active config name
#   yappr-config use <NAME>            Switch active config (atomic symlink)
#   yappr-config show [<NAME>]         Pretty-print a config (defaults to active)
#   yappr-config diff <A> <B>          Show normalized diff between two configs
#   yappr-config delete [-y] <NAME>... Delete config(s). Refuses the active config.
#   yappr-config path                  Print configs directory path
#
# Configs live at $YAPPR_ROOT/configs/*.json (default ~/toolkit/yappr/configs).

set -uo pipefail

YAPPR_ROOT="${YAPPR_ROOT:-$HOME/toolkit/yappr}"
CONFIG_DIR="$YAPPR_ROOT/configs"
ACTIVE_LINK="$CONFIG_DIR/active.json"

# ANSI colors — only when stdout is a TTY (so piped output stays clean)
if [[ -t 1 ]] && [[ "${NO_COLOR:-}" == "" ]]; then
  C_RESET=$'\e[0m'
  C_BOLD=$'\e[1m'
  C_DIM=$'\e[2m'
  C_RED=$'\e[31m'
  C_GREEN=$'\e[32m'
  C_YELLOW=$'\e[33m'
  C_BLUE=$'\e[34m'
  C_MAGENTA=$'\e[35m'
  C_CYAN=$'\e[36m'
else
  C_RESET="" C_BOLD="" C_DIM="" C_RED="" C_GREEN="" C_YELLOW="" C_BLUE="" C_MAGENTA="" C_CYAN=""
fi

die() {
  echo "${C_RED}❌${C_RESET} $*" >&2
  exit 1
}

ensure_dir() {
  [[ -d "$CONFIG_DIR" ]] || die "configs directory not found at $CONFIG_DIR"
}

active_name() {
  # Returns the basename (without .json) of whatever active.json points to,
  # or "(none)" if no active link.
  if [[ -L "$ACTIVE_LINK" ]]; then
    local target
    target=$(readlink "$ACTIVE_LINK")
    basename "${target%.json}"
  elif [[ -f "$ACTIVE_LINK" ]]; then
    echo "(not a symlink: $ACTIVE_LINK)"
  else
    echo "(none)"
  fi
}

cmd_list() {
  ensure_dir
  local active
  active=$(active_name)
  echo "${C_BOLD}${C_CYAN}🎙️  Configs in $CONFIG_DIR:${C_RESET}"
  echo
  local any=0
  # palette for cycling colors across config rows (skipping the green used for active)
  local palette=("$C_BLUE" "$C_MAGENTA" "$C_YELLOW" "$C_CYAN")
  local idx=0
  for f in "$CONFIG_DIR"/*.json; do
    [[ -e "$f" ]] || continue
    local name
    name=$(basename "${f%.json}")
    [[ "$name" == "active" ]] && continue   # skip the symlink
    any=1
    local desc
    desc=$(jq -r '.description // ""' "$f" 2>/dev/null)
    if [[ "$name" == "$active" ]]; then
      printf "  ${C_GREEN}${C_BOLD}* %-20s${C_RESET} ${C_DIM}%s${C_RESET}\n" "$name" "$desc"
    else
      local color="${palette[$((idx % ${#palette[@]}))]}"
      printf "    ${color}%-20s${C_RESET} ${C_DIM}%s${C_RESET}\n" "$name" "$desc"
      idx=$((idx + 1))
    fi
  done
  if [[ $any -eq 0 ]]; then
    echo "  ${C_DIM}(no configs yet — drop a JSON file in $CONFIG_DIR)${C_RESET}"
  fi
  echo
  echo "${C_BOLD}Active:${C_RESET} ${C_GREEN}${C_BOLD}${active}${C_RESET}"
}

cmd_active() {
  ensure_dir
  active_name
}

cmd_use() {
  ensure_dir
  local name="${1:-}"
  [[ -n "$name" ]] || die "usage: yappr-config use <NAME>"
  local target="$CONFIG_DIR/${name}.json"
  [[ -f "$target" ]] || die "config not found: $target"

  # Validate before activating
  jq empty "$target" 2>/dev/null || die "config is not valid JSON: $target"
  local got_url
  got_url=$(jq -r '.llm.url // ""' "$target")
  [[ -n "$got_url" ]] || die "config missing .llm.url: $target"

  # Atomic symlink
  ln -sfn "${name}.json" "$ACTIVE_LINK"
  echo "${C_GREEN}${C_BOLD}✓ active config is now: ${name}${C_RESET}"
  echo "  ${C_DIM}${target}${C_RESET}"
  jq -r '.description // ""' "$target" | sed "s/^/  ${C_DIM}/" | sed "s/$/${C_RESET}/"
}

cmd_show() {
  ensure_dir
  local name="${1:-}"
  local target
  if [[ -z "$name" ]]; then
    target="$ACTIVE_LINK"
    [[ -e "$target" ]] || die "no active config (run: yappr-config list)"
  else
    target="$CONFIG_DIR/${name}.json"
    [[ -f "$target" ]] || die "config not found: $target"
  fi
  jq . "$target"
}

cmd_diff() {
  ensure_dir
  local a="${1:-}"
  local b="${2:-}"
  [[ -n "$a" && -n "$b" ]] || die "usage: yappr-config diff <A> <B>"
  local af="$CONFIG_DIR/${a}.json"
  local bf="$CONFIG_DIR/${b}.json"
  [[ -f "$af" ]] || die "config not found: $af"
  [[ -f "$bf" ]] || die "config not found: $bf"
  diff -u <(jq -S . "$af") <(jq -S . "$bf") || true
}

cmd_delete() {
  ensure_dir
  local assume_yes=0
  local names=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -y|--yes) assume_yes=1; shift ;;
      -*)       die "unknown flag: $1 (usage: yappr-config delete [-y] <NAME>...)" ;;
      *)        names+=("$1"); shift ;;
    esac
  done
  [[ ${#names[@]} -gt 0 ]] || die "usage: yappr-config delete [-y] <NAME>..."

  local active
  active=$(active_name)

  # Validate everything up front so we don't half-delete on a typo.
  local targets=()
  for name in "${names[@]}"; do
    if [[ "$name" == "active" ]]; then
      die "refusing to delete the 'active' symlink (use 'yappr-config use <NAME>' to switch first)"
    fi
    if [[ "$name" == "$active" ]]; then
      die "refusing to delete the active config '$name'. Switch first: yappr-config use <other>"
    fi
    local target="$CONFIG_DIR/${name}.json"
    [[ -f "$target" ]] || die "config not found: $target"
    targets+=("$target")
  done

  # Confirm.
  if [[ $assume_yes -eq 0 ]]; then
    echo "${C_YELLOW}About to delete:${C_RESET}"
    for t in "${targets[@]}"; do
      echo "  ${C_DIM}-${C_RESET} $(basename "${t%.json}")"
    done
    read -p "Proceed? [y/N] " reply
    case "$reply" in
      [Yy]*) ;;
      *) echo "Aborted."; return 0 ;;
    esac
  fi

  for t in "${targets[@]}"; do
    rm -f "$t"
    echo "${C_GREEN}${C_BOLD}✓ deleted${C_RESET} $(basename "${t%.json}")"
  done
}

cmd_path() {
  echo "$CONFIG_DIR"
}

usage() {
  # Print the top-of-file comment block as help, stopping at the first
  # non-comment line (so the help output doesn't drift when the block grows).
  awk '
    /^#!/   { next }
    /^#/    { sub(/^# ?/, ""); print; next }
              { exit }
  ' "$0"
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    list)    cmd_list ;;
    active)  cmd_active ;;
    use)     cmd_use "$@" ;;
    show)    cmd_show "$@" ;;
    diff)    cmd_diff "$@" ;;
    delete)  cmd_delete "$@" ;;
    path)    cmd_path ;;
    ""|-h|--help|help) usage ;;
    *)       die "unknown command: $cmd (try: yappr-config help)" ;;
  esac
}

main "$@"
