#!/usr/bin/env bash
#
# yappr — local voice dictation pipeline orchestrator.
#
# WHAT IT DOES
# ------------
# Runs one full dictation cycle end-to-end:
#   audio in  →  STT (Parakeet via FluidAudio)  →  cleanup (Qwen via yappr-llm-call)
#             →  streamed text out  →  per-run JSONL metric appended.
#
# ROLE IN THE STACK
# -----------------
# This is the entry point Hammerspoon invokes when the user releases the
# Ctrl+Option+Y hotkey. Hammerspoon records audio with ffmpeg and hands the
# wav file off via YAPPR_AUDIO_FILE; yappr does everything after that.
# Cleaned text streams on STDOUT chunk-by-chunk; Hammerspoon's streamCallback
# types each chunk at the cursor as it arrives.
#
# It can also be invoked from the terminal directly — without YAPPR_AUDIO_FILE
# it records from the mic via sox, with no hotkey involved.
#
# PIPELINE STAGES (in order)
# --------------------------
#   1. PRE-FLIGHT
#      - Load active config from $YAPPR_CONFIG (default: configs/active.json).
#      - Read llm.url, model_name, max_tokens, temperature, extra_params,
#        version, hash.
#      - Hash the prompt file too (independent of config hash) so metric
#        records can distinguish prompt edits from config edits.
#      - Verify FluidAudio binary exists and llama-style endpoint is responding.
#
#   2. RECORDING (or skipped if YAPPR_AUDIO_FILE is set)
#      - Use sox + CoreAudio device named "MacBook Pro Microphone" (override
#        via YAPPR_COREAUDIO_DEVICE).
#      - Fixed duration via YAPPR_RECORD_SECS (default 10) — sox's signal
#        handling on macOS is unreliable, so we don't use VAD/SIGINT stops here.
#      - In Hammerspoon mode, ffmpeg handles the recording externally; this
#        block is skipped and YAPPR_AUDIO_FILE points at the resulting wav.
#
#   3. STT (Parakeet via FluidAudio)
#      - Invokes the compiled fluidaudiocli binary with --model-version v2
#        (English-only Parakeet) and --language en.
#      - Reads the resulting .json file, extracts .text → $RAW.
#
#   4. LLM CLEANUP (streaming via yappr-llm-call)
#      - Builds the chat-completions body using the loaded config's params,
#        merges extra_params (e.g. chat_template_kwargs.enable_thinking=false).
#      - Pipes the request JSON into yappr-llm-call. Its STDOUT (the cleaned
#        text, streamed) flows straight through to OUR stdout — no buffering.
#      - Its STDERR is captured to a temp file; the LAST line is the metric
#        JSON (text, ttft_ms, total_ms, prompt/completion tokens).
#
#   5. METRICS EMIT (synchronous JSONL append)
#      - Composes one line per run including: timestamp, llm_url, config_version,
#        config_hash, backend, model_name, prompt_hash, stt_ms, llm_ttft_ms,
#        llm_total_ms, prompt_tokens, completion_tokens, audio_seconds,
#        raw_chars, cleaned_chars.
#      - Appends to metrics/<YYYY-MM>.jsonl.
#      - Synchronous because the cost (~5-10 ms) is invisible relative to the
#        operation being measured.
#
#   6. REPORT (non-quiet mode only)
#      - Pretty-printed timings + audio path + log path go to STDERR so the
#        STDOUT text stream stays clean.
#
# OUTPUT DISCIPLINE
# -----------------
# STDOUT = cleaned text, streamed as it arrives.
# STDERR = diagnostics / log / per-stage report.
# Logs   = per-run files in logs/<timestamp>.log (also receives DEBUG-level logs).
# Metrics = metrics/<YYYY-MM>.jsonl (one JSON line per run).
# Both files use the same <timestamp> prefix so they correlate trivially.
#
# ENV VAR CONTROLS (call-time)
# ----------------------------
#   YAPPR_CONFIG            Path to active config (default: configs/active.json).
#   YAPPR_AUDIO_FILE        Use this existing wav instead of recording.
#                           Set by Hammerspoon, which captures with ffmpeg.
#   YAPPR_RECORD_SECS       Fixed recording duration in interactive mode (default 10).
#   YAPPR_COREAUDIO_DEVICE  CoreAudio input device name (default "MacBook Pro Microphone").
#   YAPPR_QUIET             "1" = stdout is JUST the streamed text, no report.
#                           Hammerspoon sets this.
#   YAPPR_COPY              "1" = also pbcopy the cleaned text to the clipboard.
#                           Independent of streaming; useful for "save to clipboard" CLI use.
#   YAPPR_DEBUG             "1" (default) = verbose log lines to the log file.
#   YAPPR_LLM_URL           Legacy override — config's llm.url wins now.
#
# EXIT CODES
# ----------
#   0  on success.
#   1  on any stage failure (mic empty, STT no JSON, LLM error, etc.).
#      Detailed reason goes to STDERR + the log file.
#
# ASSUMPTIONS / LIMITATIONS
# -------------------------
# * Requires jq, sox, python3, FluidAudio binary, and the LLM server configured
#   in active.json to be reachable.
# * Single-shot per invocation. No persistent state, no sessions — every run
#   is independent. (The LLM server may cache prefix state, but that's its
#   concern, not yappr's.)
# * Audio capture is fixed-duration on macOS because sox's signal-handling
#   under CoreAudio is broken — we tried push-to-talk and SIGINT, both fail.
#   Hammerspoon uses ffmpeg which DOES handle SIGTERM cleanly, and is the
#   intended production path.
# * Set -e is deliberately OFF (only -uo pipefail). A soft failure in one
#   stage still produces logs we can read, instead of vanishing silently.
#
# EXAMPLE
# -------
#   # Hammerspoon mode (recording done externally):
#   YAPPR_QUIET=1 YAPPR_AUDIO_FILE=/tmp/foo.wav yappr
#
#   # Interactive mode (records via sox, prints report to stderr):
#   YAPPR_RECORD_SECS=8 yappr
#

set -uo pipefail   # NB: no -e — we want to keep running even if a stage soft-fails so we can see logs

YAPPR_ROOT="${YAPPR_ROOT:-$HOME/toolkit/yappr}"
FLUIDAUDIO_DIR="$YAPPR_ROOT/vendor/FluidAudio"
FLUIDAUDIO_BIN="$FLUIDAUDIO_DIR/.build/arm64-apple-macosx/release/fluidaudiocli"
RECORDINGS_DIR="$YAPPR_ROOT/recordings"
LOGS_DIR="$YAPPR_ROOT/logs"
YAPPR_CONFIG="${YAPPR_CONFIG:-$YAPPR_ROOT/configs/active.json}"
YAPPR_DEBUG="${YAPPR_DEBUG:-1}"
YAPPR_QUIET="${YAPPR_QUIET:-0}"   # 1 = only print cleaned text to stdout, all logs to file
YAPPR_COPY="${YAPPR_COPY:-0}"     # 1 = also copy cleaned text to clipboard (pbcopy)

# Load active cleanup config — all LLM-call params come from here
if [[ ! -f "$YAPPR_CONFIG" ]]; then
  echo "❌ No yappr config at $YAPPR_CONFIG. Run: yappr-config list" >&2
  exit 1
fi
LLM_URL=$(jq -r '.llm.url' "$YAPPR_CONFIG")
MODEL_NAME=$(jq -r '.llm.model_name // ""' "$YAPPR_CONFIG")
BACKEND=$(jq -r '.backend // "unknown"' "$YAPPR_CONFIG")
MAX_TOKENS=$(jq -r '.llm.max_tokens // 512' "$YAPPR_CONFIG")
TEMPERATURE=$(jq -r '.llm.temperature // 0' "$YAPPR_CONFIG")
EXTRA_PARAMS=$(jq -c '.llm.extra_params // {}' "$YAPPR_CONFIG")
CONFIG_VERSION=$(jq -r '.version' "$YAPPR_CONFIG")
CONFIG_HASH=$(jq -cS . "$YAPPR_CONFIG" | shasum -a 256 | awk '{print substr($1,1,12)}')

PROMPT_FILE="$YAPPR_ROOT/$(jq -r '.prompt_file' "$YAPPR_CONFIG")"
PROMPT_HASH=$(shasum -a 256 "$PROMPT_FILE" 2>/dev/null | awk '{print substr($1,1,12)}')

mkdir -p "$RECORDINGS_DIR" "$LOGS_DIR"

STAMP=$(date +%Y%m%d-%H%M%S)
AUDIO="$RECORDINGS_DIR/${STAMP}.wav"
AUDIO_RAW="$RECORDINGS_DIR/${STAMP}.raw.wav"
JSON_OUT="$RECORDINGS_DIR/${STAMP}.json"
LOG_FILE="$LOGS_DIR/${STAMP}.log"

# ---------- helpers ----------
now_ms() { python3 -c 'import time; print(int(time.time()*1000))'; }
now_str() { python3 -c 'import time; t=time.time(); print(time.strftime("%H:%M:%S",time.localtime(t))+".%03d"%int((t-int(t))*1000))'; }

log() {
  local msg="[$(now_str)] $*"
  if [[ "$YAPPR_QUIET" == "1" ]]; then
    echo "$msg" >> "$LOG_FILE"
  else
    echo "$msg" | tee -a "$LOG_FILE" >&2
  fi
}

# Stop a background process cleanly: SIGINT, then SIGTERM, then SIGKILL.
stop_proc() {
  local pid=$1
  local label=$2
  local elapsed=0

  kill -INT "$pid" 2>/dev/null || true
  while kill -0 "$pid" 2>/dev/null; do
    if (( elapsed >= 20 )); then  # 2 seconds
      log "$label didn't exit on SIGINT, escalating to SIGTERM..."
      kill -TERM "$pid" 2>/dev/null || true
      sleep 1
      if kill -0 "$pid" 2>/dev/null; then
        log "$label still alive, sending SIGKILL..."
        kill -KILL "$pid" 2>/dev/null || true
      fi
      break
    fi
    sleep 0.1
    elapsed=$((elapsed + 1))
  done
  wait "$pid" 2>/dev/null || true
}

stage() {
  log ""
  log "═══ $* ═══"
}

# ---------- pre-flight checks ----------
stage "PRE-FLIGHT"
log "yappr root:      $YAPPR_ROOT"
log "fluidaudio bin:  $FLUIDAUDIO_BIN"
log "llm url:         $LLM_URL"
log "audio out:       $AUDIO"
log "json out:        $JSON_OUT"
log "log file:        $LOG_FILE"

if [[ ! -x "$FLUIDAUDIO_BIN" ]]; then
  log "❌ FluidAudio binary not found or not executable at $FLUIDAUDIO_BIN"
  exit 1
fi

if ! curl -s --max-time 2 "${LLM_URL%/chat/completions}/models" >/dev/null 2>&1; then
  log "⚠  Warning: llama-server not responding at $LLM_URL"
  log "   (will still try to transcribe, cleanup will fail)"
fi

# ---------- record (or skip if YAPPR_AUDIO_FILE points at an existing wav) ----------
stage "RECORDING"
if [[ -n "${YAPPR_AUDIO_FILE:-}" ]]; then
  # Skip recording — process an existing file (push-to-talk path)
  if [[ ! -s "$YAPPR_AUDIO_FILE" ]]; then
    log "❌ YAPPR_AUDIO_FILE=$YAPPR_AUDIO_FILE is missing or empty"
    exit 1
  fi
  log "Using pre-recorded audio from $YAPPR_AUDIO_FILE"
  cp "$YAPPR_AUDIO_FILE" "$AUDIO"
  REC_MS=0
  REC_RC=0
  T0=$(now_ms); T1=$T0
else
  RECORD_SECS="${YAPPR_RECORD_SECS:-10}"
  log "Mic capturing for ${RECORD_SECS}s (fixed duration). Override via YAPPR_RECORD_SECS."

  if [[ "$YAPPR_QUIET" != "1" ]]; then
    echo "" >&2
    echo "🎙️  RECORDING for ${RECORD_SECS}s — talk now..." >&2
  fi
  T0=$(now_ms)
  COREAUDIO_DEVICE="${YAPPR_COREAUDIO_DEVICE:-MacBook Pro Microphone}"
  if [[ "$YAPPR_QUIET" == "1" ]]; then
    sox -q -t coreaudio "$COREAUDIO_DEVICE" -c 1 -r 16000 "$AUDIO" trim 0 "$RECORD_SECS" 2>>"$LOG_FILE"
  else
    sox -t coreaudio "$COREAUDIO_DEVICE" -c 1 -r 16000 "$AUDIO" trim 0 "$RECORD_SECS"
  fi
  REC_RC=$?
  T1=$(now_ms)
  REC_MS=$((T1 - T0))
fi
log "rec exited (rc=$REC_RC) after ${REC_MS}ms"

if [[ ! -s "$AUDIO" ]]; then
  log "❌ Recording is empty. Mic permission / device issue."
  tail -10 "$LOG_FILE" >&2
  exit 1
fi

REC_SIZE=$(stat -f%z "$AUDIO" 2>/dev/null || echo 0)
REC_INFO=$(sox --i "$AUDIO" 2>&1 | tr '\n' '|' | sed 's/|/ • /g')
log "Captured: ${REC_SIZE} bytes • ${REC_INFO}"
RS_MS=0  # No separate resample stage — rec wrote 16kHz directly.

# ---------- STT ----------
stage "STT (Parakeet v2 via FluidAudio)"
T2=$(now_ms)
"$FLUIDAUDIO_BIN" transcribe "$AUDIO" \
  --model-version v2 \
  --language en \
  --output-json "$JSON_OUT" \
  >>"$LOG_FILE" 2>&1
STT_RC=$?
T3=$(now_ms)
STT_MS=$((T3 - T2))

log "FluidAudio exit code: $STT_RC"
log "STT time: ${STT_MS}ms"

if [[ ! -f "$JSON_OUT" ]]; then
  log "❌ FluidAudio did not produce JSON output at $JSON_OUT"
  log "   See log tail: $LOG_FILE"
  tail -20 "$LOG_FILE" >&2
  exit 1
fi

log "JSON output ($(stat -f%z "$JSON_OUT") bytes):"
log "$(cat "$JSON_OUT" | head -c 500)"

RAW=$(jq -r '.text // .transcript // empty' "$JSON_OUT" 2>/dev/null)
if [[ -z "$RAW" ]]; then
  log "❌ Could not extract text from JSON. Schema may differ. Full JSON:"
  cat "$JSON_OUT" >&2
  exit 1
fi

log "Extracted text: ${#RAW} chars"

# ---------- LLM cleanup ----------
stage "CLEANUP (local Qwen)"
SYSTEM_PROMPT=$(cat "$PROMPT_FILE")
log "Sending to $LLM_URL ..."

BODY=$(jq -n \
  --arg sys "$SYSTEM_PROMPT" \
  --arg raw "$RAW" \
  --argjson max_tokens "$MAX_TOKENS" \
  --argjson temperature "$TEMPERATURE" \
  --argjson extras "$EXTRA_PARAMS" \
  '{
    messages: [
      {role: "system", content: $sys},
      {role: "user",   content: $raw}
    ],
    max_tokens: $max_tokens,
    temperature: $temperature
  } + $extras')

# Streaming LLM call via the Python helper:
#  - stdout: cleaned text streams through to OUR stdout (consumer can type/display live)
#  - stderr: last line is a JSON metric blob (timing, tokens, full text) — captured below
LLM_INPUT=$(jq -n --arg url "$LLM_URL" --argjson body "$BODY" '{url:$url, body:$body, timeout:60}')
LLM_STDERR_FILE=$(mktemp -t yappr-llm-stderr.XXXXXX)
echo "$LLM_INPUT" | "$YAPPR_ROOT/bin/yappr-llm-call" 2>"$LLM_STDERR_FILE"
LLM_RC=$?

# The metric JSON is the LAST stderr line; any preceding stderr goes to the log
LLM_METRIC=$(tail -1 "$LLM_STDERR_FILE")
head -n -1 "$LLM_STDERR_FILE" >> "$LOG_FILE" 2>/dev/null || true
rm -f "$LLM_STDERR_FILE"

LLM_ERR=$(echo "$LLM_METRIC" | jq -r '.error // empty' 2>/dev/null)
LLM_TTFT_MS=$(echo "$LLM_METRIC" | jq -r '.ttft_ms // 0' 2>/dev/null)
LLM_MS=$(echo     "$LLM_METRIC" | jq -r '.total_ms // 0' 2>/dev/null)
CLEANED=$(echo    "$LLM_METRIC" | jq -r '.text // empty' 2>/dev/null)
PROMPT_TOK=$(echo "$LLM_METRIC" | jq -r '.prompt_tokens // 0' 2>/dev/null)
COMPLETION_TOK=$(echo "$LLM_METRIC" | jq -r '.completion_tokens // 0' 2>/dev/null)

log "LLM helper exit: $LLM_RC"
log "TTFT: ${LLM_TTFT_MS}ms"
log "Cleanup time: ${LLM_MS}ms"
log "Tokens: prompt=$PROMPT_TOK completion=$COMPLETION_TOK"

if [[ $LLM_RC -ne 0 ]] || [[ -n "$LLM_ERR" ]]; then
  log "❌ LLM call failed: ${LLM_ERR:-rc=$LLM_RC}"
  exit 1
fi

if [[ -z "$CLEANED" ]]; then
  log "❌ LLM produced empty text. Last stderr line:"
  echo "$LLM_METRIC" >&2
  exit 1
fi

USAGE="{\"prompt_tokens\":$PROMPT_TOK,\"completion_tokens\":$COMPLETION_TOK}"
log "Token usage: $USAGE"

# ---------- metrics (synchronous JSONL append) ----------
METRIC_FILE="$YAPPR_ROOT/metrics/$(date +%Y-%m).jsonl"
mkdir -p "$(dirname "$METRIC_FILE")"
AUDIO_SECONDS=$(sox --i -D "$AUDIO" 2>/dev/null | head -1 || echo 0)
[[ -z "$AUDIO_SECONDS" ]] && AUDIO_SECONDS=0
# PROMPT_TOK / COMPLETION_TOK already set by yappr-llm-call helper above

jq -nc \
  --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  --arg llm_url "$LLM_URL" \
  --arg config_version "$CONFIG_VERSION" \
  --arg config_hash "$CONFIG_HASH" \
  --arg backend "$BACKEND" \
  --arg model_name "$MODEL_NAME" \
  --arg prompt_hash "$PROMPT_HASH" \
  --argjson stt_ms "$STT_MS" \
  --argjson llm_ttft_ms "$LLM_TTFT_MS" \
  --argjson llm_total_ms "$LLM_MS" \
  --argjson prompt_tokens "$PROMPT_TOK" \
  --argjson completion_tokens "$COMPLETION_TOK" \
  --argjson audio_seconds "$AUDIO_SECONDS" \
  --argjson raw_chars "${#RAW}" \
  --argjson cleaned_chars "${#CLEANED}" \
  '{ts:$ts, llm_url:$llm_url,
    config_version:$config_version, config_hash:$config_hash,
    backend:$backend, model_name:$model_name, prompt_hash:$prompt_hash,
    stt_ms:$stt_ms, llm_ttft_ms:$llm_ttft_ms, llm_total_ms:$llm_total_ms,
    prompt_tokens:$prompt_tokens, completion_tokens:$completion_tokens,
    audio_seconds:$audio_seconds,
    raw_chars:$raw_chars, cleaned_chars:$cleaned_chars}' \
  >> "$METRIC_FILE" 2>>"$LOG_FILE"

log "Metric appended to $METRIC_FILE"

# ---------- report ----------
TOTAL_MS=$((STT_MS + LLM_MS))

# Copy to clipboard if requested
if [[ "$YAPPR_COPY" == "1" ]]; then
  printf "%s" "$CLEANED" | pbcopy
  log "Copied to clipboard."
fi

# Cleaned text was already streamed to stdout chunk-by-chunk during the LLM call.
# In non-quiet mode, append timings to stderr so the user sees them without
# polluting the stdout text stream.
if [[ "$YAPPR_QUIET" != "1" ]]; then
  {
    echo
    echo "─────────────────────────────────────"
    echo "RAW (from STT): $RAW"
    echo "─────────────────────────────────────"
    printf "⏱  Record:  %5d ms (%s of audio)\n" "$REC_MS" "$(echo "scale=2; $REC_MS/1000" | bc)s"
    printf "⏱  Resample:%5d ms\n" "$RS_MS"
    printf "⏱  STT:     %5d ms\n" "$STT_MS"
    printf "⏱  LLM TTFT:%5d ms\n" "$LLM_TTFT_MS"
    printf "⏱  Cleanup: %5d ms\n" "$LLM_MS"
    printf "⏱  Total (post-stop): %d ms\n" "$TOTAL_MS"
    echo "    Audio:    $AUDIO"
    echo "    Log:      $LOG_FILE"
  } >&2
fi
