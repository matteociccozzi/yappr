#!/usr/bin/env bash
#
# yappr — local voice dictation pipeline orchestrator.
#
# WHAT IT DOES
# ------------
# Runs one full dictation cycle end-to-end:
#   mic (via daemon)  →  STT (Nemotron 0.6B streaming, in-daemon)
#                     →  cleanup (Qwen via yappr-llm-call)
#                     →  streamed text out  →  per-run JSONL metric appended.
#
# ROLE IN THE STACK
# -----------------
# This is the entry point Hammerspoon invokes when the user releases the
# Ctrl+Option+Y hotkey. A long-running Swift daemon (yappr-stt-daemon) owns
# the mic via AVAudioEngine and runs streaming STT; yappr spawns a tiny Swift
# socket client (YapprSttConnect) that connects to /tmp/yappr-stt.sock — the
# connection itself is what tells the daemon to open the mic. Hammerspoon
# sends SIGTERM on hotkey-release, the client half-closes, the daemon
# finalizes, and the transcript comes back on the client's stdout.
# Cleaned text streams on STDOUT chunk-by-chunk; Hammerspoon's streamCallback
# types each chunk at the cursor as it arrives.
#
# PIPELINE STAGES (in order)
# --------------------------
#   1. FAST-PATH SOCKET CONNECT (latency-critical)
#      - Verify /tmp/yappr-stt.sock exists; spawn YapprSttConnect in the
#        background BEFORE doing any other work. Connecting opens the mic in
#        the daemon, so config-load / preflight runs in parallel with audio
#        capture instead of delaying it. Swift binary startup (~3-5 ms) is
#        the only unavoidable cost on the head of the recording.
#
#   2. PRE-FLIGHT (runs in parallel with recording)
#      - Load active config from $YAPPR_CONFIG (default: configs/active.json).
#      - Read llm.url, model_name, max_tokens, temperature, extra_params,
#        version, hash.
#      - Hash the prompt file too (independent of config hash) so metric
#        records can distinguish prompt edits from config edits.
#      - Health-check the llama-style endpoint (warn-only, non-fatal).
#
#   3. WAIT + STT FINALIZE
#      - Wait for SIGTERM (Hammerspoon hotkey release) or Ctrl+C; trap forwards
#        it to YapprSttConnect, which half-closes the socket. Daemon finalizes
#        the stream, returns the transcript on the client's stdout, client
#        exits. Stderr from the client carries audio_ms / finalize_ms /
#        total_ms which we scrape for the metrics record.
#      - Empty transcript = silent exit 0 (user released without speaking).
#
#   4. LLM CLEANUP (streaming via yappr-llm-call)
#      - Builds the chat-completions body using the loaded config's params,
#        merges extra_params (e.g. chat_template_kwargs.enable_thinking=false).
#      - Pipes the request JSON into yappr-llm-call. Its STDOUT (the cleaned
#        text, streamed) flows straight through to OUR stdout — no buffering.
#      - Its STDERR is captured to a temp file; the LAST line is the metric
#        JSON (text, ttft_ms, total_ms, prompt/completion tokens).
#
#   5. METRICS EMIT (synchronous JSONL append)
#      - Composes one line per run including: timestamp, llm_url, config_version,
#        config_hash, backend, model_name, prompt_hash, stt_ms,
#        stt_total_held_ms, llm_ttft_ms, llm_total_ms, prompt/completion tokens,
#        audio_seconds, raw_chars, cleaned_chars.
#      - Appends to metrics/<YYYY-MM>.jsonl.
#      - Synchronous because the cost (~5-10 ms) is invisible relative to the
#        operation being measured.
#
#   6. REPORT (non-quiet mode only)
#      - Pretty-printed timings + log path go to STDERR so the STDOUT text
#        stream stays clean.
#
# OUTPUT DISCIPLINE
# -----------------
# STDOUT = cleaned text, streamed as it arrives.
# STDERR = diagnostics / log / per-stage report.
# Logs   = per-run files in logs/<timestamp>.log (also receives DEBUG-level logs).
# Metrics = metrics/<YYYY-MM>.jsonl (one JSON line per run).
#
# ENV VAR CONTROLS (call-time)
# ----------------------------
#   YAPPR_CONFIG            Path to active config (default: configs/active.json).
#   YAPPR_QUIET             "1" = stdout is JUST the streamed text, no report.
#                           Hammerspoon sets this.
#   YAPPR_COPY              "1" = also pbcopy the cleaned text to the clipboard.
#                           Independent of streaming; useful for "save to clipboard" CLI use.
#   YAPPR_DEBUG             "1" (default) = verbose log lines to the log file.
#   YAPPR_ROOT              Override the repo root (auto-detected from script location).
#
# EXIT CODES
# ----------
#   0  on success (including empty transcript).
#   1  on any stage failure (missing daemon socket, missing config, LLM error, etc.).
#      Detailed reason goes to STDERR + the log file.
#
# ASSUMPTIONS / LIMITATIONS
# -------------------------
# * Requires jq, python3, the yappr-stt-daemon running with its socket at
#   /tmp/yappr-stt.sock, and the LLM server configured in active.json reachable.
# * Single-shot per invocation. No persistent state in yappr itself — the
#   daemon stays warm across invocations so the STT model isn't reloaded.
# * Set -e is deliberately OFF (only -uo pipefail). A soft failure in one
#   stage still produces logs we can read, instead of vanishing silently.
#
# EXAMPLE
# -------
#   # Hammerspoon mode:
#   YAPPR_QUIET=1 yappr
#
#   # Interactive mode (talk, Ctrl+C to stop, report printed to stderr):
#   yappr
#

set -uo pipefail   # NB: no -e — we want to keep running even if a stage soft-fails so we can see logs

# shellcheck disable=SC1091  # path resolved dynamically at runtime
source "$(dirname "${BASH_SOURCE[0]}")/_yappr-paths.sh"
yappr_ensure_dirs
YAPPR_QUIET="${YAPPR_QUIET:-0}"   # 1 = only print cleaned text to stdout, all logs to file
YAPPR_COPY="${YAPPR_COPY:-0}"     # 1 = also copy cleaned text to clipboard (pbcopy)

# --- LATENCY-CRITICAL FAST PATH ---
# The daemon opens the mic when we connect to the socket, so any work before
# THIS LINE means truncated audio. Bash startup is the only thing we cannot
# avoid; everything else (config-load, jq, log file setup, curl health check)
# is deferred until AFTER the helper is spawned and recording in background.
if [[ ! -S "$YAPPR_SOCKET" ]]; then
  echo "❌ daemon socket not found at $YAPPR_SOCKET" >&2
  echo "   start it first: $(yappr_daemon_binary) &" >&2
  exit 1
fi

STREAM_OUT=$(mktemp -t yappr-stream-out.XXXXXX)
STREAM_ERR=$(mktemp -t yappr-stream-err.XXXXXX)

# Spawn the Swift client IMMEDIATELY. It opens the unix socket (which is
# what signals the daemon to start the mic), then blocks reading. SIGTERM
# (= Hammerspoon hotkey release) triggers the half-close. Swift binary
# startup is ~3-5 ms vs python3's ~30-50 ms — the difference is audio we
# would otherwise lose at the start of the dictation.
"$(yappr_connect_binary)" >"$STREAM_OUT" 2>"$STREAM_ERR" &
STREAM_PID=$!
trap 'kill -TERM '"$STREAM_PID"' 2>/dev/null' TERM INT

# --- everything below runs in parallel with the recording ---
# The mic is open and capturing while bash does config-load + preflight.

YAPPR_DEBUG="${YAPPR_DEBUG:-1}"

# Load active cleanup config — all LLM-call params come from here
if [[ ! -f "$YAPPR_CONFIG" ]]; then
  echo "❌ No yappr config at $YAPPR_CONFIG. Run: yappr-config list" >&2
  kill -TERM "$STREAM_PID" 2>/dev/null
  exit 1
fi
LLM_URL=$(jq -r '.llm.url' "$YAPPR_CONFIG")
MODEL_NAME=$(jq -r '.llm.model_name // ""' "$YAPPR_CONFIG")
BACKEND=$(jq -r '.backend // "unknown"' "$YAPPR_CONFIG")
MAX_TOKENS=$(jq -r '.llm.max_tokens // 512' "$YAPPR_CONFIG")
TEMPERATURE=$(jq -r '.llm.temperature // 0' "$YAPPR_CONFIG")
EXTRA_PARAMS=$(jq -c '.llm.extra_params // {}' "$YAPPR_CONFIG")
CONFIG_VERSION=$(jq -r '.version' "$YAPPR_CONFIG")
CONFIG_HASH=$(jq -cS . "$YAPPR_CONFIG" | shasum -a 256 | awk '{print substr($1,1,12)}')

PROMPT_FILE="$YAPPR_SHARE/$(jq -r '.prompt_file' "$YAPPR_CONFIG")"
PROMPT_HASH=$(shasum -a 256 "$PROMPT_FILE" 2>/dev/null | awk '{print substr($1,1,12)}')

LOG_FILE="$(yappr_log_path)"

# ---------- helpers ----------
now_ms() { python3 -c 'import time; print(int(time.time()*1000))'; }
now_str() { python3 -c 'import time; t=time.time(); print(time.strftime("%H:%M:%S",time.localtime(t))+".%03d"%int((t-int(t))*1000))'; }

log() {
  local msg
  msg="[$(now_str)] $*"
  if [[ "$YAPPR_QUIET" == "1" ]]; then
    echo "$msg" >> "$LOG_FILE"
  else
    echo "$msg" | tee -a "$LOG_FILE" >&2
  fi
}

# Stop a background process cleanly: SIGINT, then SIGTERM, then SIGKILL.
stop_proc() {
  local pid=$1
  local label=$2
  local elapsed=0

  kill -INT "$pid" 2>/dev/null || true
  while kill -0 "$pid" 2>/dev/null; do
    if (( elapsed >= 20 )); then  # 2 seconds
      log "$label didn't exit on SIGINT, escalating to SIGTERM..."
      kill -TERM "$pid" 2>/dev/null || true
      sleep 1
      if kill -0 "$pid" 2>/dev/null; then
        log "$label still alive, sending SIGKILL..."
        kill -KILL "$pid" 2>/dev/null || true
      fi
      break
    fi
    sleep 0.1
    elapsed=$((elapsed + 1))
  done
  wait "$pid" 2>/dev/null || true
}

stage() {
  log ""
  log "═══ $* ═══"
}

# ---------- pre-flight (logged after the fact; mic is already open) ----------
stage "PRE-FLIGHT"
log "yappr root:      $YAPPR_ROOT"
log "llm url:         $LLM_URL"
log "log file:        $LOG_FILE"

if ! curl -s --max-time 2 "${LLM_URL%/chat/completions}/models" >/dev/null 2>&1; then
  log "⚠  Warning: llama-server not responding at $LLM_URL"
  log "   (will still try to transcribe, cleanup will fail)"
fi

# ---------- record + STT (in-daemon mic, streaming via yappr-stt-daemon) ----------
stage "STT (in-daemon mic + streaming Nemotron 0.6B)"

if [[ "$YAPPR_QUIET" != "1" ]]; then
  echo "" >&2
  echo "🎙️  RECORDING — talk now, release hotkey (or Ctrl+C) to stop..." >&2
fi

# The python helper is already spawned (above) and recording in the
# background. Wait for SIGTERM (Hammerspoon hotkey release) → helper half-
# closes the socket → daemon finalizes → helper exits with transcript on
# stdout. `wait` returns 128+signum after the trap fires without waiting for
# the child to actually exit, so we spin on kill -0 until reaped.
wait "$STREAM_PID"
while kill -0 "$STREAM_PID" 2>/dev/null; do sleep 0.02; done
trap - TERM INT

STREAM_LOG=$(cat "$STREAM_ERR")
echo "$STREAM_LOG" >> "$LOG_FILE"
AUDIO_MS=$(echo "$STREAM_LOG" | grep -oE 'audio_ms=[0-9]+' | tail -1 | cut -d= -f2)
FINALIZE_MS=$(echo "$STREAM_LOG" | grep -oE 'finalize_ms=[0-9]+' | tail -1 | cut -d= -f2)
HELPER_TOTAL_MS=$(echo "$STREAM_LOG" | grep -oE 'total_ms=[0-9]+' | tail -1 | cut -d= -f2)
[[ -z "$AUDIO_MS" ]] && AUDIO_MS=0
[[ -z "$FINALIZE_MS" ]] && FINALIZE_MS=0
[[ -z "$HELPER_TOTAL_MS" ]] && HELPER_TOTAL_MS=0
# TOTAL_HELD_MS reflects helper t_start → transcript-received. The bash work
# that runs in parallel with the helper doesn't extend the user-perceived
# delay, so this is the right metric.
TOTAL_HELD_MS=$HELPER_TOTAL_MS

# Semantic shift: with streaming, stt_ms covers only the post-EOF finalize
# (typically ~30 ms). The new stt_total_held_ms field captures press-to-transcript
# wallclock for end-to-end visibility. Compare across the schema bump in
# configs/default.json (version: "v3-streaming") in yappr-stats.
STT_MS=$FINALIZE_MS
# shellcheck disable=SC2034  # REC_MS preserved for metrics schema compat
REC_MS=$AUDIO_MS
# shellcheck disable=SC2034  # RS_MS legacy re-sample duration field; always 0 with streaming
RS_MS=0
AUDIO_SECONDS=$(python3 -c "print($AUDIO_MS/1000.0)")

RAW=$(cat "$STREAM_OUT")
rm -f "$STREAM_OUT" "$STREAM_ERR"

log "audio_ms=$AUDIO_MS finalize_ms=$FINALIZE_MS total_held_ms=$TOTAL_HELD_MS"

# Empty transcript: user pressed-and-released without speech, or the model
# couldn't recognize anything. Not a hard error — skip the LLM cleanup and
# exit 0 silently so Hammerspoon doesn't pop an alert.
if [[ -z "$RAW" ]]; then
  log "empty transcript (no speech detected); skipping LLM cleanup"
  exit 0
fi

log "Raw transcript (${#RAW} chars): $RAW"

# ---------- LLM cleanup ----------
stage "CLEANUP (local Qwen)"
SYSTEM_PROMPT=$(cat "$PROMPT_FILE")
log "Sending to $LLM_URL ..."

BODY=$(jq -n \
  --arg sys "$SYSTEM_PROMPT" \
  --arg raw "$RAW" \
  --argjson max_tokens "$MAX_TOKENS" \
  --argjson temperature "$TEMPERATURE" \
  --argjson extras "$EXTRA_PARAMS" \
  '{
    messages: [
      {role: "system", content: $sys},
      {role: "user",   content: $raw}
    ],
    max_tokens: $max_tokens,
    temperature: $temperature
  } + $extras')

# Streaming LLM call via the Python helper:
#  - stdout: cleaned text streams through to OUR stdout (consumer can type/display live)
#  - stderr: last line is a JSON metric blob (timing, tokens, full text) — captured below
LLM_INPUT=$(jq -n --arg url "$LLM_URL" --argjson body "$BODY" '{url:$url, body:$body, timeout:60}')
LLM_STDERR_FILE=$(mktemp -t yappr-llm-stderr.XXXXXX)
echo "$LLM_INPUT" | "$YAPPR_ROOT/bin/yappr-llm-call" 2>"$LLM_STDERR_FILE"
LLM_RC=$?

# The metric JSON is the LAST stderr line; any preceding stderr goes to the log
LLM_METRIC=$(tail -1 "$LLM_STDERR_FILE")
head -n -1 "$LLM_STDERR_FILE" >> "$LOG_FILE" 2>/dev/null || true
rm -f "$LLM_STDERR_FILE"

LLM_ERR=$(echo "$LLM_METRIC" | jq -r '.error // empty' 2>/dev/null)
LLM_TTFT_MS=$(echo "$LLM_METRIC" | jq -r '.ttft_ms // 0' 2>/dev/null)
LLM_MS=$(echo     "$LLM_METRIC" | jq -r '.total_ms // 0' 2>/dev/null)
CLEANED=$(echo    "$LLM_METRIC" | jq -r '.text // empty' 2>/dev/null)
PROMPT_TOK=$(echo "$LLM_METRIC" | jq -r '.prompt_tokens // 0' 2>/dev/null)
COMPLETION_TOK=$(echo "$LLM_METRIC" | jq -r '.completion_tokens // 0' 2>/dev/null)

log "LLM helper exit: $LLM_RC"
log "TTFT: ${LLM_TTFT_MS}ms"
log "Cleanup time: ${LLM_MS}ms"
log "Tokens: prompt=$PROMPT_TOK completion=$COMPLETION_TOK"

if [[ $LLM_RC -ne 0 ]] || [[ -n "$LLM_ERR" ]]; then
  log "❌ LLM call failed: ${LLM_ERR:-rc=$LLM_RC}"
  exit 1
fi

if [[ -z "$CLEANED" ]]; then
  log "❌ LLM produced empty text. Last stderr line:"
  echo "$LLM_METRIC" >&2
  exit 1
fi

USAGE="{\"prompt_tokens\":$PROMPT_TOK,\"completion_tokens\":$COMPLETION_TOK}"
log "Token usage: $USAGE"

# ---------- metrics (synchronous JSONL append) ----------
# AUDIO_SECONDS was set from AUDIO_MS in the streaming STT block above.
METRIC_FILE="$(yappr_metric_path)"

jq -nc \
  --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  --arg llm_url "$LLM_URL" \
  --arg config_version "$CONFIG_VERSION" \
  --arg config_hash "$CONFIG_HASH" \
  --arg backend "$BACKEND" \
  --arg model_name "$MODEL_NAME" \
  --arg prompt_hash "$PROMPT_HASH" \
  --argjson stt_ms "$STT_MS" \
  --argjson stt_total_held_ms "$TOTAL_HELD_MS" \
  --argjson llm_ttft_ms "$LLM_TTFT_MS" \
  --argjson llm_total_ms "$LLM_MS" \
  --argjson prompt_tokens "$PROMPT_TOK" \
  --argjson completion_tokens "$COMPLETION_TOK" \
  --argjson audio_seconds "$AUDIO_SECONDS" \
  --argjson raw_chars "${#RAW}" \
  --argjson cleaned_chars "${#CLEANED}" \
  '{ts:$ts, llm_url:$llm_url,
    config_version:$config_version, config_hash:$config_hash,
    backend:$backend, model_name:$model_name, prompt_hash:$prompt_hash,
    stt_ms:$stt_ms, stt_total_held_ms:$stt_total_held_ms,
    llm_ttft_ms:$llm_ttft_ms, llm_total_ms:$llm_total_ms,
    prompt_tokens:$prompt_tokens, completion_tokens:$completion_tokens,
    audio_seconds:$audio_seconds,
    raw_chars:$raw_chars, cleaned_chars:$cleaned_chars}' \
  >> "$METRIC_FILE" 2>>"$LOG_FILE"

log "Metric appended to $METRIC_FILE"

# ---------- report ----------
TOTAL_MS=$((STT_MS + LLM_MS))

# Copy to clipboard if requested
if [[ "$YAPPR_COPY" == "1" ]]; then
  printf "%s" "$CLEANED" | pbcopy
  log "Copied to clipboard."
fi

# Cleaned text was already streamed to stdout chunk-by-chunk during the LLM call.
# In non-quiet mode, append timings to stderr so the user sees them without
# polluting the stdout text stream.
if [[ "$YAPPR_QUIET" != "1" ]]; then
  # ANSI colors only when stderr is a TTY and NO_COLOR isn't set
  # shellcheck disable=SC2034  # R_* vars used via "${R_*}" expansions in printf/echo below
  if [[ -t 2 ]] && [[ "${NO_COLOR:-}" == "" ]]; then
    R_RESET=$'\e[0m'; R_BOLD=$'\e[1m'; R_DIM=$'\e[2m'
    R_RED=$'\e[31m'; R_GREEN=$'\e[32m'; R_YELLOW=$'\e[33m'
    R_BLUE=$'\e[34m'; R_MAGENTA=$'\e[35m'; R_CYAN=$'\e[36m'
  else
    R_RESET="" R_BOLD="" R_DIM="" R_RED="" R_GREEN="" R_YELLOW="" R_BLUE="" R_MAGENTA="" R_CYAN=""
  fi
  {
    echo
    echo "${R_DIM}─────────────────────────────────────${R_RESET}"
    echo "${R_DIM}RAW (from STT):${R_RESET} ${R_BOLD}${RAW}${R_RESET}"
    echo "${R_DIM}─────────────────────────────────────${R_RESET}"
    printf "${R_CYAN}⏱  Held:${R_RESET}        ${R_BOLD}%5d ms${R_RESET}  ${R_DIM}(%s of audio)${R_RESET}\n" \
           "$TOTAL_HELD_MS" "$(echo "scale=2; $AUDIO_MS/1000" | bc)s"
    printf "${R_MAGENTA}⏱  STT finalize:${R_RESET}${R_BOLD}%5d ms${R_RESET}  ${R_DIM}(post-EOF)${R_RESET}\n" "$STT_MS"
    printf "${R_YELLOW}⏱  LLM TTFT:${R_RESET}    ${R_BOLD}%5d ms${R_RESET}\n" "$LLM_TTFT_MS"
    printf "${R_GREEN}⏱  Cleanup:${R_RESET}     ${R_BOLD}%5d ms${R_RESET}\n" "$LLM_MS"
    printf "${R_BOLD}⏱  Total (post-stop):${R_RESET} ${R_BOLD}%d ms${R_RESET}\n" "$TOTAL_MS"
    echo "    ${R_DIM}Log:${R_RESET}      $LOG_FILE"
  } >&2
fi
